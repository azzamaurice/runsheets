{
    "semi": false,
    "singleQuote": true,
    "tabWidth": 4,
    "trailingComma": "none",
    "printWidth": 100,
    "bracketSpacing": true,
    "arrowParens": "avoid",
    "bracketSameLine": true,
    "singleAttributePerLine": true,
    "vueIndentScriptAndStyle": false,
    "plugins": ["prettier-plugin-tailwindcss", "@prettier/plugin-xml"],
    "tailwindFunctions": ["cva", "cn"],
    "overrides": [
        {
            "files": "*.json",
            "options": {
                "tabWidth": 2
            }
        },
        {
            "files": "*.svg",
            "options": {
                "xmlWhitespaceSensitivity": "ignore"
            }
        }
    ]
}
